{
  "slug": "simkl_sync",
  "name": "Simkl Sync",
  "version": "1.0.0",
  "description": "Two-way watched-state sync with Simkl: pulls your Simkl history into mydia and pushes what you watch in mydia back to Simkl.",
  "author": "Mydia",
  "min_host_version": "1.1.0",
  "capabilities": {
    "events:subscribe": ["playback.finished"],
    "net:http": ["api.simkl.com", "simkl.com"],
    "state:kv": [],
    "data:read": ["playback_progress"],
    "surfaces:write": ["playback:watched"],
    "users:connections": [],
    "schedule:interval": []
  },
  "schedule": {
    "interval_minutes": 30
  },
  "connection": {
    "type": "oauth_device",
    "code_url": "https://api.simkl.com/oauth/pin?client_id={client_id}",
    "poll_url": "https://api.simkl.com/oauth/pin/{user_code}?client_id={client_id}",
    "verification_url": "https://simkl.com/pin",
    "client_id": "a419f0c96f1071ef4a8459a0fc8cc45f4615e7863d836e877c98e8850ca0603e"
  },
  "settings_schema": [
    {
      "key": "client_id",
      "type": "string",
      "label": "Simkl client_id (override the bundled default)"
    },
    {
      "key": "api_base",
      "type": "string",
      "label": "Simkl API base URL (advanced / testing)"
    }
  ]
}
