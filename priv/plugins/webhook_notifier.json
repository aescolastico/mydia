{
  "slug": "webhook-notifier",
  "name": "Webhook Notifier",
  "version": "1.0.0",
  "description": "Posts a notification to Discord or your own ntfy server when media is added or a download completes.",
  "author": "Mydia",
  "entrypoint": "handle",
  "capabilities": {
    "events:subscribe": ["media_item.added", "download.completed"],
    "net:http": ["discord.com"],
    "data:read": ["media_item"]
  },
  "settings_schema": [
    {
      "key": "target",
      "type": "enum",
      "label": "Target service",
      "required": true,
      "options": ["discord", "ntfy"]
    },
    {
      "key": "webhook_url",
      "type": "url",
      "label": "Webhook / server URL",
      "required": true,
      "grants_host": true
    },
    {
      "key": "ntfy_priority",
      "type": "string",
      "label": "ntfy priority (1-5, optional)"
    },
    {
      "key": "ntfy_tags",
      "type": "string",
      "label": "ntfy tags (comma-separated, optional)"
    },
    {
      "key": "ntfy_token",
      "type": "secret",
      "label": "ntfy access token (optional)"
    }
  ]
}
