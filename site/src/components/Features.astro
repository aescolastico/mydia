---
const features = [
  {
    title: 'Media Library',
    description: 'Organize your movies and TV shows with automatic file detection and library management.',
    icon: 'film',
  },
  {
    title: 'Automatic Metadata',
    description: 'Fetches artwork, descriptions, ratings, and episode data from TVDB and TMDB automatically.',
    icon: 'sparkles',
  },
  {
    title: 'P2P Remote Access',
    description: 'Stream your media from anywhere with decentralized peer-to-peer connectivity. No port forwarding needed.',
    icon: 'globe',
  },
  {
    title: 'Self-Hosted',
    description: 'Run on your own hardware. Your data stays yours with complete privacy and control.',
    icon: 'server',
  },
  {
    title: 'Episode Tracking',
    description: 'Track seasons, episodes, and watch progress across your entire TV collection.',
    icon: 'list',
  },
  {
    title: 'Docker Deploy',
    description: 'Get up and running in minutes with a single Docker Compose file. Zero configuration hassle.',
    icon: 'box',
  },
];

const iconPaths: Record<string, string> = {
  film: 'M7 4v16M17 4v16M3 8h4m6 0h4m2 0h4M3 12h18M3 16h4m6 0h4m2 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z',
  sparkles: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z',
  globe: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9',
  server: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01',
  list: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01',
  box: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
};
---

<section class="py-20 px-4 bg-base-200/50">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">
      Everything you need
    </h2>
    <p class="text-base-content/60 text-center mb-14 max-w-xl mx-auto">
      A complete media management solution built for self-hosters.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map(feature => (
        <div class="card bg-base-100 border border-base-300 hover:border-primary/30 transition-colors">
          <div class="card-body">
            <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[feature.icon]} />
              </svg>
            </div>
            <h3 class="card-title text-lg">{feature.title}</h3>
            <p class="text-base-content/60 text-sm">{feature.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
