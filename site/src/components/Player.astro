const features = [
  { title: 'P2P Streaming', description: 'Stream from your server over an encrypted peer-to-peer mesh. No port forwarding or VPN required.' },
  { title: 'Offline Downloads', description: 'Download media to your device for offline viewing on the go.' },
  { title: 'Native Playback', description: 'Hardware-accelerated video playback with support for HLS streaming.' },
];
---

<section id="player" class="py-20 px-4 bg-base-200/50 scroll-mt-16">
  <div class="max-w-6xl mx-auto">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <span class="badge badge-primary badge-outline mb-4">Mydia Player</span>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">
          Watch anywhere
        </h2>
        <p class="text-base-content/60 mb-8 leading-relaxed">
          The Mydia Player is a cross-platform app that connects directly to your server.
          Stream your media from any device with secure, decentralized P2P connectivity.
        </p>

        <div class="space-y-4 mb-8">
          {features.map(feature => (
            <div class="flex gap-3">
              <div class="w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-primary" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-sm">{feature.title}</h3>
                <p class="text-base-content/50 text-sm">{feature.description}</p>
              </div>
            </div>
          ))}
        </div>

        <a
          href="https://github.com/getmydia/mydia/releases/latest"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary mb-8"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10.75 2.75a.75.75 0 00-1.5 0v8.614L6.295 8.235a.75.75 0 10-1.09 1.03l4.25 4.5a.75.75 0 001.09 0l4.25-4.5a.75.75 0 00-1.09-1.03l-2.955 3.129V2.75z" />
            <path d="M3.5 12.75a.75.75 0 00-1.5 0v2.5A2.75 2.75 0 004.75 18h10.5A2.75 2.75 0 0018 15.25v-2.5a.75.75 0 00-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H4.75c-.69 0-1.25-.56-1.25-1.25v-2.5z" />
          </svg>
          Download Player
        </a>

        <div>
          <p class="text-xs text-base-content/40 uppercase tracking-wider font-medium mb-3">Available on</p>
          <div class="flex flex-wrap gap-2">
            {platforms.map(platform => (
              <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-base-300/50 text-sm text-base-content/70">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill={platform.name === 'Web' ? 'none' : 'currentColor'} stroke={platform.name === 'Web' ? 'currentColor' : 'none'} stroke-width={platform.name === 'Web' ? '2' : '0'}>
                  <path stroke-linecap="round" stroke-linejoin="round" d={platform.icon} />
                </svg>
                {platform.name}
                {platform.note && (
                  <span class="text-xs text-base-content/40">({platform.note})</span>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="flex justify-center gap-6">
        <!-- Phone mockup 1: Home screen -->
        <div class="relative">
          <div class="w-[240px] rounded-[2rem] border-4 border-base-content/20 bg-base-300 p-1.5 shadow-2xl">
            <div class="w-full rounded-[1.5rem] overflow-hidden">
              <img src="/img/player-2.png" alt="Mydia Player home screen" class="w-full" loading="lazy" />
            </div>
          </div>
          <div class="absolute -inset-4 bg-primary/5 rounded-[3rem] -z-10 blur-2xl"></div>
        </div>
        <!-- Phone mockup 2: Downloads screen -->
        <div class="relative hidden sm:block mt-12">
          <div class="w-[240px] rounded-[2rem] border-4 border-base-content/20 bg-base-300 p-1.5 shadow-2xl">
            <div class="w-full rounded-[1.5rem] overflow-hidden">
              <img src="/img/player-1.png" alt="Mydia Player downloads screen" class="w-full" loading="lazy" />
            </div>
          </div>
          <div class="absolute -inset-4 bg-primary/5 rounded-[3rem] -z-10 blur-2xl"></div>
        </div>
      </div>
    </div>
  </div>
</section>
