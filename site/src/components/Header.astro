---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: 'https://getmydia.github.io/mydia/latest/', label: 'Docs', external: true },
  { href: 'https://github.com/getmydia/mydia', label: 'GitHub', external: true },
];
---

<header class="navbar bg-base-200/80 backdrop-blur-md sticky top-0 z-50 border-b border-base-300">
  <div class="max-w-6xl mx-auto w-full px-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
      <img src="/img/logo.svg" alt="Mydia" class="w-7 h-7" />
      <span class="text-xl font-bold tracking-tight">mydia</span>
    </a>
    <nav class="flex items-center gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="btn btn-ghost btn-sm"
          {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {link.label}
          {link.external && (
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 ml-0.5 opacity-50" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 00-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 00.75-.75v-4a.75.75 0 011.5 0v4A2.25 2.25 0 0112.75 17h-8.5A2.25 2.25 0 012 14.75v-8.5A2.25 2.25 0 014.25 4h5a.75.75 0 010 1.5h-5zm7.25-.75a.75.75 0 01.75-.75h3.5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0V6.31l-5.47 5.47a.75.75 0 11-1.06-1.06l5.47-5.47H12.25a.75.75 0 01-.75-.75z" clip-rule="evenodd" />
            </svg>
          )}
        </a>
      ))}
    </nav>
  </div>
</header>
