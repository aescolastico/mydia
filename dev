#!/usr/bin/env bash

# Dev command wrapper for the devenv-based developer environment.
#
# The daily loop runs natively under devenv (devenv.sh) — no Docker dev
# container. Each git worktree derives its own non-colliding ports and isolated
# state (see devenv.nix). This wrapper is a thin shim over devenv that preserves
# the historical `./dev` command vocabulary.
#
# Unchanged, intentionally NOT devenv-backed:
#   - relay <build|push|restart|deploy>   (Docker + kubectl)
#   - player android <build|run|shell>    (player/flake.nix, native Nix)
#   - player e2e / e2e-build              (Docker E2E stack, compose.player-e2e.yml)

set -e

# Colors for output. ANSI-C quoting ($'...') stores real ESC bytes so the codes
# render correctly both in `echo -e` and in the `cat <<EOF` help block.
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
NC=$'\033[0m' # No Color

# Resolve project root (directory containing this script) so the wrapper works
# from any cwd within the worktree.
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

# Ensure devenv is available, with an actionable hint otherwise (R12 error path).
if ! command -v devenv &> /dev/null; then
    echo -e "${RED}Error: devenv is not installed or not on PATH${NC}"
    echo "This project uses devenv for local development. Set it up with:"
    echo "  1. Install Nix:    https://nixos.org/download"
    echo "  2. Install devenv: nix profile install nixpkgs#devenv"
    echo "  3. Install direnv: https://direnv.net  (then 'direnv allow' in this worktree)"
    echo "See docs/development/setup.md for the full first-run guide."
    exit 1
fi

if [ ! -f "$ROOT_DIR/devenv.nix" ]; then
    echo -e "${RED}Error: devenv.nix not found in $ROOT_DIR${NC}"
    echo "Please run this script from the project root directory."
    exit 1
fi

# Run a command inside the devenv shell (loads the env if not already active).
# Usage: in_shell mix deps.get
in_shell() {
    devenv shell -- "$@"
}

# Run a shell snippet inside the devenv shell (for chained/`cd` commands with
# NO user-supplied arguments — never interpolate "$@"/"$*" into the snippet, as
# that loses quoting and lets shell metacharacters through).
# Usage: in_shell_sh "cd player && flutter pub get"
in_shell_sh() {
    devenv shell -- bash -c "$1"
}

# Run a command (argv-safe) inside the devenv shell from the player/ directory.
# Args are passed positionally, so quoting/whitespace and metacharacters are
# preserved exactly. Usage: in_player flutter pub get
in_player() {
    devenv shell -- bash -c 'cd player && exec "$@"' _ "$@"
}

# Show help if no arguments provided
if [ $# -eq 0 ]; then
    cat <<EOF
${GREEN}Mydia Development Helper (devenv)${NC}

Usage: ./dev <command> [arguments...]

Each git worktree runs its own stack on deterministic, non-colliding ports
(derived from the worktree path; override in devenv.local.nix). Enter a worktree
with direnv (auto) or run any command below.

${YELLOW}Process Lifecycle (devenv processes):${NC}
  up [-d]              Start the stack (phoenix + flutter codegen, +postgres if
                      DATABASE_TYPE=postgres). Add -d for background.
  down                 Stop background processes
  stop                 Stop processes
  start                Start processes in the background
  restart              Restart the background stack
  logs <process>       Show recent logs for a process (e.g. 'logs phoenix';
                       no live-follow — use foreground 'up' to stream live)
  ps                   List managed processes and their status

${YELLOW}Shells & Mix:${NC}
  shell                Open an interactive devenv shell
  bash                 Open a bash shell in the devenv environment
  iex                  Start IEx (iex -S mix)
  mix <args>           Run a mix command
  mix precommit        Run precommit checks natively (compact summary)

${YELLOW}Development Commands:${NC}
  test [args]          Run tests (mix test) natively, with test-DB setup
  feature-test [args]  Run Wallaby browser tests (uses in-shell chromedriver)
  format               Format code (mix format)
  deps.get             Install dependencies
  ecto.migrate         Run database migrations
  ecto.reset           Reset database
  phx.server           Start the Phoenix server (foreground)

${YELLOW}User Management:${NC}
  user list [--role=R] List all users (optionally filter by role)
  user add <email> <username> [opts]
                       Add a new user (--password, --role, --display-name)
  user delete <id>     Delete a user by email or username
  user reset-password <id> [--password=P]
                       Reset a user's password

${YELLOW}Player (Flutter):${NC}
  flutter <args>       Run any flutter command (in player/)
  player setup         Install deps and run code generation
  player build         Build + deploy web assets to priv/static/player
  player shell         Open a shell in the player directory
  player logs          Show recent build_runner (codegen) process logs
  player restart       Restart the flutter-codegen process
  player e2e [opts]    Run player E2E integration tests (Docker)
  player e2e-build     Pre-build E2E images (Docker)

${YELLOW}Player Android (native, uses player/flake.nix):${NC}
  player android build Build Android APK (release)
  player android run   Build and run on connected Android device
  player android shell Open nix develop shell in player directory

${YELLOW}Metadata Relay (Docker + kubectl):${NC}
  relay deploy         Build, push :dev image, and redeploy to k8s
  relay build          Build :dev Docker image only
  relay push           Push :dev image to ghcr.io
  relay restart        Restart deployment (pull latest image)

${YELLOW}Examples:${NC}
  ./dev up -d                    # Start the stack in the background
  ./dev logs phoenix             # Show Phoenix logs
  ./dev mix test                 # Run tests
  ./dev mix ecto.migrate         # Run migrations
  ./dev user list                # List all users
  ./dev player logs              # Show recent build_runner (codegen) logs

EOF
    exit 0
fi

# ── Native precommit: reproduce the historical 6-step compact summary ─────────
# (Mirrors the prior Docker run_precommit; now native against the active adapter.
# Default SQLite serializes async tests; set DATABASE_TYPE=postgres to run the
# warm-Postgres parallel path. This adapter choice is the deferred tuning item
# from the migration plan's Open Questions.)
print_test_rerun_hints() {
    echo ""
    echo -e "${YELLOW}── Re-run failed tests ──${NC}"
    echo "  ./dev test --failed              Re-run previously failed tests"
    echo "  ./dev test path/to_test.exs:42   Re-run a specific test"
    echo "  ./dev test path/to_test.exs      Re-run a specific file"
}

run_precommit() {
    # Run all six steps inside a SINGLE devenv shell so the environment (and the
    # enterShell setup-task guards) load once and _build/test stays warm across
    # steps — no per-step shell re-entry, no recompilation between steps. Runs
    # against the active adapter (SQLite by default; DATABASE_TYPE=postgres keeps
    # async tests parallel — the deferred KTD6 tuning knob).
    devenv shell -- bash <<'PRECOMMIT'
set +e
GREEN='\033[0;32m'; RED='\033[0;31m'; NC='\033[0m'
export MIX_ENV=test
declare -a FAILED_STEPS FAILED_OUTPUTS
any_failed=0

run_step() {
    local label="$1" cmd="$2" output exit_code start elapsed
    printf "  %-30s" "$label"
    start=$SECONDS
    output=$(eval "$cmd" 2>&1); exit_code=$?
    elapsed=$(( SECONDS - start ))
    if [ $exit_code -eq 0 ]; then
        local summary=""
        [ "$label" = "Tests" ] && summary=$(echo "$output" | grep -oE '[0-9]+ tests?, [0-9]+ failures?' | tail -1)
        if [ -n "$summary" ]; then echo -e "${GREEN}✓${NC} $summary (${elapsed}s)"; else echo -e "${GREEN}✓${NC} ${elapsed}s"; fi
    else
        echo -e "${RED}✗${NC} ${elapsed}s"
        local f; f=$(mktemp /tmp/mydia-precommit-XXXXXX.log); echo "$output" > "$f"
        local filtered; filtered=$(echo "$output" | sed 's/\x1b\[[0-9;]*m//g' | sed -n '/^  [0-9]\+) /,/^$/p; /^Finished in/p; /^[0-9]\+ tests\?/p')
        [ -z "$filtered" ] && filtered=$(echo "$output" | tail -20)
        FAILED_STEPS+=("$label"); FAILED_OUTPUTS+=("$(printf '%s\n\nFull output: %s' "$filtered" "$f")")
        any_failed=1
    fi
}

echo "Precommit"
run_step "Dependencies" "mix deps.get >/dev/null 2>&1 || mix deps.get"
run_step "Compile"      "mix compile --warnings-as-errors"
run_step "Unused deps"  "mix deps.unlock --unused"
run_step "Format"       "mix format --check-formatted"
run_step "Database"     "mix ecto.create --quiet && mix ecto.migrate --quiet"
run_step "Tests"        "mix test --color"

echo ""
if [ ${#FAILED_OUTPUTS[@]} -gt 0 ]; then
    for i in "${!FAILED_STEPS[@]}"; do
        echo -e "${RED}── ${FAILED_STEPS[$i]} ──${NC}"
        echo "${FAILED_OUTPUTS[$i]}"
        echo ""
    done
fi

if [ $any_failed -ne 0 ]; then echo -e "${RED}✗ Precommit failed${NC}"; exit 1; else echo -e "${GREEN}✓ Precommit passed${NC}"; exit 0; fi
PRECOMMIT
}

# Parse command
COMMAND=$1
shift

case "$COMMAND" in
    # ── Process lifecycle ────────────────────────────────────────────────────
    up)
        echo -e "${GREEN}Starting devenv processes...${NC}"
        devenv up "$@"
        ;;
    down)
        echo -e "${GREEN}Stopping devenv processes...${NC}"
        devenv processes down
        ;;
    stop)
        echo -e "${GREEN}Stopping devenv processes...${NC}"
        devenv processes stop "$@"
        ;;
    start)
        echo -e "${GREEN}Starting devenv processes in the background...${NC}"
        devenv up -d "$@"
        ;;
    restart)
        echo -e "${GREEN}Restarting devenv processes...${NC}"
        devenv processes down >/dev/null 2>&1 || true
        devenv up -d "$@"
        ;;
    logs)
        # `devenv processes logs` shows recent lines for ONE named process and
        # does not follow (no -f). For a live stream of everything, run `./dev up`
        # in the foreground. Translate a historical -f/--follow into a hint
        # rather than forwarding an unsupported flag.
        follow=false
        log_args=()
        for a in "$@"; do
            case "$a" in
                -f|--follow) follow=true ;;
                *) log_args+=("$a") ;;
            esac
        done
        if [ "$follow" = true ]; then
            echo -e "${YELLOW}Note: 'logs' shows recent lines only — devenv has no live-follow.${NC}"
            echo -e "${YELLOW}      Run './dev up' (foreground) to stream all processes live.${NC}"
        fi
        if [ ${#log_args[@]} -eq 0 ]; then
            echo -e "${YELLOW}Specify a process, e.g.:${NC} ./dev logs phoenix"
            echo "Managed processes: phoenix, flutter-codegen (plus postgres when DATABASE_TYPE=postgres)."
            echo "Use './dev ps' to list them, or './dev up' (foreground) to stream all live."
            exit 0
        fi
        devenv processes logs "${log_args[@]}"
        ;;
    ps)
        devenv processes list
        ;;

    # ── Shells & mix ─────────────────────────────────────────────────────────
    shell|sh)
        echo -e "${GREEN}Entering devenv shell...${NC}"
        devenv shell
        ;;
    bash)
        echo -e "${GREEN}Opening bash in the devenv environment...${NC}"
        in_shell bash
        ;;
    iex)
        echo -e "${GREEN}Starting IEx...${NC}"
        if [ $# -gt 0 ]; then
            in_shell iex "$@"
        else
            in_shell iex -S mix
        fi
        ;;
    mix)
        if [[ "$1" == "precommit" ]]; then
            run_precommit
        elif [[ "$1" == "test" ]]; then
            echo -e "${GREEN}Running tests...${NC}"
            test_exit_code=0
            in_shell mix test --color "${@:2}" || test_exit_code=$?
            [ $test_exit_code -ne 0 ] && print_test_rerun_hints
            exit $test_exit_code
        else
            in_shell mix "$@"
        fi
        ;;

    # ── Development shortcuts ────────────────────────────────────────────────
    test)
        echo -e "${GREEN}Running tests...${NC}"
        test_exit_code=0
        in_shell mix test --color "$@" || test_exit_code=$?
        [ $test_exit_code -ne 0 ] && print_test_rerun_hints
        exit $test_exit_code
        ;;
    feature-test)
        echo -e "${GREEN}Running feature tests (Wallaby browser tests)...${NC}"
        in_shell env MIX_ENV=test ./scripts/run-feature-tests.sh "$@"
        ;;
    format)
        echo -e "${GREEN}Formatting code...${NC}"
        in_shell mix format
        ;;
    deps.get)
        echo -e "${GREEN}Installing dependencies...${NC}"
        in_shell mix deps.get
        ;;
    ecto.migrate)
        echo -e "${GREEN}Running migrations...${NC}"
        in_shell mix ecto.migrate
        ;;
    ecto.reset)
        echo -e "${GREEN}Resetting database...${NC}"
        in_shell mix ecto.reset
        ;;
    phx.server)
        echo -e "${GREEN}Starting Phoenix server...${NC}"
        in_shell mix phx.server
        ;;

    # ── User management ──────────────────────────────────────────────────────
    user)
        if [ $# -eq 0 ]; then
            echo -e "${RED}Error: user command requires a subcommand${NC}"
            echo "Usage: ./dev user <list|add|delete|reset-password> [args...]"
            exit 1
        fi
        in_shell mix mydia.user "$@"
        ;;

    # ── Flutter / player ─────────────────────────────────────────────────────
    flutter)
        echo -e "${GREEN}Running flutter command...${NC}"
        in_player flutter "$@"
        ;;
    player)
        case "$1" in
            logs)
                echo -e "${GREEN}Showing recent build_runner (codegen) process logs...${NC}"
                devenv processes logs flutter-codegen
                ;;
            build)
                echo -e "${GREEN}Building player web assets...${NC}"
                in_shell_sh "cd player && flutter build web --release --base-href /player/ --tree-shake-icons"
                echo -e "${GREEN}Copying build output to priv/static/player...${NC}"
                in_shell_sh "rm -rf priv/static/player && cp -r player/build/web priv/static/player"
                in_shell_sh "[ -f player/web/manifest.json ] && cp player/web/manifest.json priv/static/player/ || true"
                echo -e "${GREEN}Build deployed successfully!${NC}"
                ;;
            setup)
                echo -e "${GREEN}Setting up player project (pub get + build_runner)...${NC}"
                in_shell_sh "cd player && flutter pub get && flutter pub run build_runner build --delete-conflicting-outputs"
                echo -e "${GREEN}Player project setup complete!${NC}"
                ;;
            shell)
                echo -e "${GREEN}Opening shell in player directory...${NC}"
                in_shell_sh "cd player && exec bash"
                ;;
            restart)
                echo -e "${GREEN}Restarting flutter-codegen process...${NC}"
                devenv processes restart flutter-codegen
                ;;
            e2e)
                shift
                rebuild_images=false
                test_target="integration_test/pairing_flow_test.dart"
                test_args=""
                while [ $# -gt 0 ]; do
                    case "$1" in
                        --build) rebuild_images=true ;;
                        --target)
                            if [ -z "$2" ]; then
                                echo -e "${RED}Error: --target requires a test file path${NC}"
                                exit 1
                            fi
                            test_target="$2"; shift ;;
                        --)
                            shift
                            [ $# -gt 0 ] && test_args="$*"
                            break ;;
                        *) test_args="${test_args:+$test_args }$1" ;;
                    esac
                    shift
                done
                echo -e "${GREEN}Running player E2E integration tests (Docker)...${NC}"
                echo "Test target: $test_target"
                if [ "$rebuild_images" = true ]; then
                    DOCKER_BUILDKIT=1 docker compose -f compose.player-e2e.yml build
                fi
                E2E_TEST_TARGET="$test_target" E2E_TEST_ARGS="$test_args" \
                    docker compose -f compose.player-e2e.yml up --abort-on-container-exit --exit-code-from test
                exit_code=$?
                docker compose -f compose.player-e2e.yml down -v
                exit $exit_code
                ;;
            e2e-build)
                echo -e "${GREEN}Pre-building player E2E images (Docker)...${NC}"
                DOCKER_BUILDKIT=1 docker compose -f compose.player-e2e.yml build
                echo -e "${GREEN}E2E images pre-built successfully!${NC}"
                ;;
            android)
                # Android builds use the player's flake.nix (native, not devenv)
                if ! command -v nix &> /dev/null; then
                    echo -e "${RED}Error: nix is not installed${NC}"
                    echo "Android builds require Nix. Install from: https://nixos.org/download.html"
                    exit 1
                fi
                case "$2" in
                    build)
                        echo -e "${GREEN}Building Android APK using player/flake.nix...${NC}"
                        nix develop ./player --command bash -c "cd player && flutter pub get && flutter build apk --release"
                        if [ $? -eq 0 ]; then
                            echo -e "${GREEN}APK built successfully!${NC}"
                            echo "Output: player/build/app/outputs/flutter-apk/app-release.apk"
                        fi
                        ;;
                    run)
                        echo -e "${GREEN}Building and running on Android device...${NC}"
                        extra_args="${@:3}"
                        nix develop ./player --command bash -c "cd player && flutter pub get && flutter run $extra_args"
                        ;;
                    shell)
                        echo -e "${GREEN}Opening nix develop shell in player directory...${NC}"
                        cd player && nix develop
                        ;;
                    *)
                        echo -e "${RED}Error: Unknown android command: $2${NC}"
                        echo "Usage: ./dev player android <build|run|shell>"
                        exit 1
                        ;;
                esac
                ;;
            *)
                echo -e "${RED}Error: Unknown player command: $1${NC}"
                echo "Usage: ./dev player <logs|build|setup|shell|restart|e2e|e2e-build|android>"
                exit 1
                ;;
        esac
        ;;

    # ── Metadata relay deployment (Docker + kubectl, unchanged) ──────────────
    relay)
        RELAY_IMAGE="ghcr.io/getmydia/mydia/metadata-relay:dev"
        RELAY_NAMESPACE="metadata-relay"
        RELAY_DEPLOYMENT="metadata-relay"
        case "$1" in
            build)
                echo -e "${GREEN}Building metadata-relay:dev Docker image...${NC}"
                docker build -f metadata-relay/Dockerfile -t "$RELAY_IMAGE" .
                echo -e "${GREEN}Build complete!${NC}"
                ;;
            push)
                echo -e "${GREEN}Pushing metadata-relay:dev to ghcr.io...${NC}"
                docker push "$RELAY_IMAGE"
                echo -e "${GREEN}Push complete!${NC}"
                ;;
            restart)
                echo -e "${GREEN}Restarting metadata-relay deployment...${NC}"
                kubectl rollout restart deployment/"$RELAY_DEPLOYMENT" -n "$RELAY_NAMESPACE"
                kubectl rollout status deployment/"$RELAY_DEPLOYMENT" -n "$RELAY_NAMESPACE" --timeout=120s
                echo -e "${GREEN}Deployment restarted successfully!${NC}"
                ;;
            deploy)
                echo -e "${GREEN}Building, pushing, and deploying metadata-relay:dev...${NC}"
                echo -e "${YELLOW}[1/3] Building Docker image...${NC}"
                docker build -f metadata-relay/Dockerfile -t "$RELAY_IMAGE" . || { echo -e "${RED}Build failed!${NC}"; exit 1; }
                echo -e "${GREEN}Build complete!${NC}"
                echo -e "${YELLOW}[2/3] Pushing to ghcr.io...${NC}"
                docker push "$RELAY_IMAGE" || { echo -e "${RED}Push failed!${NC}"; exit 1; }
                PUSHED_DIGEST=$(docker inspect --format='{{index .RepoDigests 0}}' "$RELAY_IMAGE" 2>/dev/null | cut -d'@' -f2)
                echo -e "${GREEN}Push complete!${NC}"
                echo -e "${YELLOW}[3/3] Restarting deployment...${NC}"
                kubectl rollout restart deployment/"$RELAY_DEPLOYMENT" -n "$RELAY_NAMESPACE"
                kubectl rollout status deployment/"$RELAY_DEPLOYMENT" -n "$RELAY_NAMESPACE" --timeout=120s || { echo -e "${RED}Deployment failed!${NC}"; exit 1; }
                RUNNING_DIGEST=$(kubectl get pod -n "$RELAY_NAMESPACE" -l app.kubernetes.io/name=metadata-relay -o jsonpath='{.items[0].status.containerStatuses[0].imageID}' 2>/dev/null | cut -d'@' -f2)
                if [ -n "$PUSHED_DIGEST" ] && [ -n "$RUNNING_DIGEST" ]; then
                    if [ "$PUSHED_DIGEST" = "$RUNNING_DIGEST" ]; then
                        echo -e "${GREEN}Image digests match!${NC}"
                    else
                        echo -e "${YELLOW}Warning: Digests don't match (may need time to pull)${NC}"
                    fi
                fi
                echo -e "${GREEN}Deployment complete!${NC}"
                ;;
            *)
                echo -e "${RED}Error: Unknown relay command: $1${NC}"
                echo "Usage: ./dev relay <deploy|build|push|restart>"
                exit 1
                ;;
        esac
        ;;

    *)
        echo -e "${RED}Error: Unknown command: $COMMAND${NC}"
        echo "Run './dev' with no arguments to see available commands."
        exit 1
        ;;
esac
