# Metadata Relay Infrastructure Configuration
# Copy this file to config.yaml and fill in your values

# Cloudflare Configuration
# Create API token at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone:DNS:Edit
cloudflare_api_token: "your-cloudflare-api-token"

# Find Zone ID at: Cloudflare Dashboard > Select domain > Overview (right sidebar)
cloudflare_zone_id: "your-cloudflare-zone-id"

# Domain Configuration
domain_name: "mydia.dev"
relay_subdomain: "relay"

# Application Secrets
# Generate with: openssl rand -hex 32
relay_secret_key_base: "generate-with-openssl-rand-hex-32"

# TVDB API key from: https://thetvdb.com/dashboard/account/apikeys
relay_tvdb_api_key: "your-tvdb-api-key"

# TMDB API key from: https://www.themoviedb.org/settings/api
relay_tmdb_api_key: "your-tmdb-api-key"

# Feedback email notifications (optional)
# All six fields below must be set together for the relay to send feedback emails.
# Leave blank to disable. Stored locally only — never committed to git.
relay_smtp_host: ""
relay_smtp_port: "587"
relay_smtp_username: ""
relay_smtp_password: ""
relay_feedback_email_to: ""
relay_feedback_email_from: ""
relay_feedback_dashboard_url: ""

# Monitoring
# Leave empty to auto-generate on first deploy
grafana_admin_password: ""

# Shared OAuth (oauth2-proxy)
# Create a GitHub OAuth App at: https://github.com/organizations/getmydia/settings/applications
# Homepage URL: https://auth.mydia.dev
# Authorization callback URL: https://auth.mydia.dev/oauth2/callback
oauth2_proxy_client_id: "your-github-oauth-client-id"
oauth2_proxy_client_secret: "your-github-oauth-client-secret"
# Leave empty to auto-generate on first deploy
oauth2_proxy_cookie_secret: ""

# Analytics (Plausible CE)
# Leave empty to auto-generate on first deploy
plausible_secret_key_base: ""
plausible_totp_vault_key: ""
plausible_postgres_password: ""

# SSH Configuration
ssh_public_key_path: "~/.ssh/id_ed25519.pub"

# VPS Configuration (populated automatically after first deploy)
vps_name: ""
vps_ip: ""
