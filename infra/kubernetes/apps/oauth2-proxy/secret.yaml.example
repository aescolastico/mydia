# oauth2-proxy secrets
# Copy this file to secret.yaml and update the values
# Or let the deploy script create it automatically
apiVersion: v1
kind: Secret
metadata:
  name: oauth2-proxy-secrets
  namespace: oauth2-proxy
  labels:
    app.kubernetes.io/name: oauth2-proxy
    app.kubernetes.io/component: authentication
type: Opaque
stringData:
  # GitHub OAuth App credentials
  # Create at: https://github.com/organizations/getmydia/settings/applications
  # Callback URL: https://auth.mydia.dev/oauth2/callback
  OAUTH2_PROXY_CLIENT_ID: "your-github-oauth-client-id"
  OAUTH2_PROXY_CLIENT_SECRET: "your-github-oauth-client-secret"
  # Generate with: python3 -c "import secrets; import base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
  OAUTH2_PROXY_COOKIE_SECRET: "generate-a-32-byte-base64-cookie-secret"
