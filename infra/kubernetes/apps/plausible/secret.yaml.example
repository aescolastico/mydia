# Plausible analytics secrets
# Copy this file to secret.yaml and update the values
# Or let the deploy script create it automatically
apiVersion: v1
kind: Secret
metadata:
  name: plausible-secrets
  namespace: plausible
  labels:
    app.kubernetes.io/name: plausible
    app.kubernetes.io/component: analytics
type: Opaque
stringData:
  # Generate with: openssl rand -base64 48
  SECRET_KEY_BASE: "change-me-generate-with-openssl-rand-base64-48"

  # Generate with: openssl rand -base64 32
  TOTP_VAULT_KEY: "change-me-generate-with-openssl-rand-base64-32"

  # Password for the Plausible PostgreSQL database
  POSTGRES_PASSWORD: "change-me"

---
# Instructions:
# 1. Copy this file to secret.yaml
# 2. Replace all placeholder values with actual secrets
# 3. Apply: kubectl apply -f secret.yaml
# 4. DO NOT commit secret.yaml to version control
