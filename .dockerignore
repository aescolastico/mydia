# VCS
.git
.gitignore

# Build/test outputs
_build
cover
tmp

# Elixir deps/cache from host (always rebuilt in image)
deps
.elixir_ls
.hex
.mix
.nix-mix

# Databases and local runtime state
*.db
*.db-shm
*.db-wal

# Flutter/Dart generated artifacts
player/.dart_tool
player/.pub-cache
player/build
player/android/build
player/.flutter-plugins
player/.flutter-plugins-dependencies
player/.packages

# Rust build artifacts
player/rust/**/target
native/**/target
plugins/**/target

# Built WASM plugin guests — rebuilt from source by the :plugins compiler inside
# the image. Excluding them keeps a stale/local host artifact out of the build
# context so the image always reflects committed source.
priv/plugins/*.wasm

# Metadata relay local build artifacts
metadata-relay/_build
metadata-relay/deps
metadata-relay/.nix-hex
metadata-relay/.nix-mix

# Misc local artifacts
screenshots
*.log
