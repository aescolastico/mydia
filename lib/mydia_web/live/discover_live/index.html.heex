<Layouts.app {assigns}>
  <div class="space-y-5 md:space-y-6">
    <%!-- Header --%>
    <div>
      <h1 class="text-3xl font-bold">Discover</h1>
      <p class="text-base-content/70 mt-1">
        Find new {if @media_type == :movie, do: "movies", else: "TV shows"} to add to your library
      </p>
    </div>

    <%!-- Controls card --%>
    <div class="card bg-base-100 shadow-sm">
      <div class="card-body p-3 md:p-4 space-y-3">
        <%!-- Media type toggle + category tabs --%>
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
          <div class="join">
            <button
              phx-click="switch_media_type"
              phx-value-type="movie"
              class={["join-item btn btn-sm gap-1.5", @media_type == :movie && "btn-active"]}
            >
              <.icon name="hero-film" class="w-4 h-4" /> Movies
            </button>
            <button
              phx-click="switch_media_type"
              phx-value-type="tv_show"
              class={["join-item btn btn-sm gap-1.5", @media_type == :tv_show && "btn-active"]}
            >
              <.icon name="hero-tv" class="w-4 h-4" /> TV Shows
            </button>
          </div>

          <div role="tablist" class="tabs tabs-box w-fit">
            <%= for {cat_key, cat_label} <- @categories do %>
              <button
                role="tab"
                phx-click="switch_category"
                phx-value-category={cat_key}
                class={["tab tab-sm", @category == cat_key && "tab-active"]}
              >
                {cat_label}
              </button>
            <% end %>
            <button
              role="tab"
              phx-click="switch_category"
              phx-value-category="discover"
              class={["tab tab-sm gap-1", @category == :discover && "tab-active"]}
            >
              <.icon name="hero-adjustments-horizontal" class="w-3.5 h-3.5" /> Custom
            </button>
          </div>
        </div>

        <%!-- Filter controls — only visible in custom/discover mode --%>
        <%= if @category == :discover do %>
          <form
            id="discover-filter-form"
            phx-change="apply_filters"
            class="flex flex-wrap items-center gap-2"
          >
            <div class="join">
              <select name="genre" class="select select-bordered select-sm join-item">
                <option value="">All Genres</option>
                <%= for genre <- @genres do %>
                  <option
                    value={genre.id}
                    selected={to_string(genre.id) in @selected_genres}
                  >
                    {genre.name}
                  </option>
                <% end %>
              </select>

              <select name="language" class="select select-bordered select-sm join-item">
                <option value="">All Languages</option>
                <%= for {code, name} <- @languages do %>
                  <option value={code} selected={@selected_language == code}>
                    {name}
                  </option>
                <% end %>
              </select>

              <select name="year" class="select select-bordered select-sm join-item">
                <option value="">All Years</option>
                <%= for year <- Enum.to_list(Date.utc_today().year..1970//-1) do %>
                  <option value={year} selected={@selected_year == year}>
                    {year}
                  </option>
                <% end %>
              </select>

              <select name="rating" class="select select-bordered select-sm join-item">
                <option value="">Any Rating</option>
                <%= for rating <- [9, 8, 7, 6, 5] do %>
                  <option
                    value={rating}
                    selected={@min_rating != nil && round(@min_rating) == rating}
                  >
                    {rating}+ Stars
                  </option>
                <% end %>
              </select>
            </div>

            <%!-- Sort --%>
            <div class="divider divider-horizontal mx-0 hidden sm:flex"></div>
            <div class="flex items-center gap-1.5">
              <.icon
                name="hero-arrows-up-down"
                class="w-4 h-4 text-base-content/50 shrink-0"
              />
              <select name="sort" class="select select-bordered select-sm">
                <%= for {value, label} <- @sort_options do %>
                  <option value={value} selected={@sort_by == value}>
                    {label}
                  </option>
                <% end %>
              </select>
            </div>
          </form>
        <% end %>
      </div>
    </div>

    <%!-- Results --%>
    <%= cond do %>
      <% @loading -> %>
        <div class="flex flex-col items-center justify-center py-16 gap-3">
          <span class="loading loading-spinner loading-lg text-primary"></span>
          <p class="text-sm text-base-content/60">
            Loading {if @media_type == :movie, do: "movies", else: "TV shows"}...
          </p>
        </div>
      <% @items == [] -> %>
        <div class="flex flex-col items-center justify-center py-16 gap-4">
          <div class="bg-base-200 rounded-full p-6">
            <.icon name="hero-magnifying-glass" class="w-10 h-10 text-base-content/40" />
          </div>
          <div class="text-center">
            <p class="text-lg font-medium text-base-content/80">No results found</p>
            <p class="text-sm text-base-content/50 mt-1">
              Try adjusting your filters or search terms
            </p>
          </div>
        </div>
      <% true -> %>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4 md:gap-5">
          <%= for item <- @items do %>
            <.trending_card
              item={item}
              media_type={item.media_type || @media_type}
              current_user={@current_user}
              adding_item_id={@adding_item_id}
            />
          <% end %>
        </div>

        <%!-- Load more trigger --%>
        <%= if @has_more do %>
          <div
            id="load-more-trigger"
            phx-click="load_more"
            class="flex items-center justify-center py-8"
          >
            <%= if @loading_more do %>
              <span class="loading loading-spinner loading-md text-primary"></span>
            <% else %>
              <button class="btn btn-ghost btn-sm text-base-content/60">
                Load more <.icon name="hero-chevron-down" class="w-4 h-4" />
              </button>
            <% end %>
          </div>
        <% end %>
    <% end %>
  </div>

  <%!-- Detail Modal --%>
  <.live_component
    module={MydiaWeb.Live.Components.TrendingDetailModal}
    id="discover-detail-modal"
    item={@selected_item}
    metadata={@selected_metadata}
    loading={@detail_loading}
    current_user={@current_user}
    open={@selected_item != nil}
  />
</Layouts.app>
