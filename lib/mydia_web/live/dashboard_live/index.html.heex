<Layouts.app {assigns}>
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
    <div>
      <h1 class="text-3xl font-bold">Welcome to Mydia</h1>
      <p class="text-base-content/70 mt-1">Your personal media management system</p>
    </div>
  </div>

  <!-- Player CTA Banner -->
  <a
    href="/player"
    class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow mb-6 md:mb-8"
  >
    <div class="card-body flex-col sm:flex-row sm:items-center gap-4">
      <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
        <.icon name="hero-play-circle-solid" class="w-6 h-6 text-primary" />
      </div>
      <div class="flex-1 min-w-0">
        <h3 class="font-semibold">Open the Mydia Player</h3>
        <p class="text-sm text-base-content/60">
          Watch your library right here — no separate app needed.
        </p>
      </div>
      <span class="btn btn-primary btn-sm self-start sm:self-center shrink-0">
        Launch Player <.icon name="hero-arrow-right" class="w-4 h-4" />
      </span>
    </div>
  </a>

  <!-- Stats Cards -->
  <div class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4 mb-6 md:mb-8">
    <!-- Movies Card -->
    <div class="card bg-base-100 shadow-sm">
      <div class="card-body">
        <h2 class="card-title">
          <.icon name="hero-film" class="w-6 h-6 text-primary" /> Movies
        </h2>
        <p class="text-3xl font-bold">{@movie_count}</p>
        <p class="text-sm text-base-content/60">Total movies</p>
      </div>
    </div>

    <!-- TV Shows Card -->
    <div class="card bg-base-100 shadow-sm">
      <div class="card-body">
        <h2 class="card-title">
          <.icon name="hero-tv" class="w-6 h-6 text-primary" /> TV Shows
        </h2>
        <p class="text-3xl font-bold">{@tv_show_count}</p>
        <p class="text-sm text-base-content/60">Total series</p>
      </div>
    </div>

    <!-- Downloads Card -->
    <div class="card bg-base-100 shadow-sm">
      <div class="card-body">
        <h2 class="card-title">
          <.icon name="hero-arrow-down-tray" class="w-6 h-6 text-primary" /> Downloads
        </h2>
        <p class="text-3xl font-bold">{@active_downloads_count}</p>
        <p class="text-sm text-base-content/60">Active downloads</p>
      </div>
    </div>

    <!-- Storage Card -->
    <div class="card bg-base-100 shadow-sm">
      <div class="card-body">
        <h2 class="card-title">
          <.icon name="hero-circle-stack" class="w-6 h-6 text-primary" /> Storage
        </h2>
        <p class="text-3xl font-bold">{@total_storage}</p>
        <p class="text-sm text-base-content/60">Total storage used</p>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="mb-6 md:mb-8">
    <h2 class="text-2xl font-bold mb-3 md:mb-4">Quick Actions</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
      <%= if @current_user && @current_user.role == "guest" do %>
        <%!-- Guest users see request options --%>
        <.link
          navigate={~p"/request/movie"}
          class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow"
        >
          <div class="card-body flex-row items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
              <.icon name="hero-film" class="w-6 h-6 text-primary" />
            </div>
            <div class="flex-1">
              <h3 class="font-semibold">Request Movie</h3>
              <p class="text-sm text-base-content/60">Submit a movie request</p>
            </div>
          </div>
        </.link>

        <.link
          navigate={~p"/request/series"}
          class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow"
        >
          <div class="card-body flex-row items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-secondary/10 flex items-center justify-center">
              <.icon name="hero-tv" class="w-6 h-6 text-secondary" />
            </div>
            <div class="flex-1">
              <h3 class="font-semibold">Request Series</h3>
              <p class="text-sm text-base-content/60">Submit a series request</p>
            </div>
          </div>
        </.link>

        <.link
          navigate={~p"/requests"}
          class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow"
        >
          <div class="card-body flex-row items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center">
              <.icon name="hero-queue-list" class="w-6 h-6 text-accent" />
            </div>
            <div class="flex-1">
              <h3 class="font-semibold">My Requests</h3>
              <p class="text-sm text-base-content/60">View your requests</p>
            </div>
          </div>
        </.link>
      <% else %>
        <%!-- Admin users see add and import options --%>
        <.link
          navigate={~p"/add/movie"}
          class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow"
        >
          <div class="card-body flex-row items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
              <.icon name="hero-plus" class="w-6 h-6 text-primary" />
            </div>
            <div class="flex-1">
              <h3 class="font-semibold">Add Movie</h3>
              <p class="text-sm text-base-content/60">Search and add movies</p>
            </div>
          </div>
        </.link>

        <.link
          navigate={~p"/add/series"}
          class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow"
        >
          <div class="card-body flex-row items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-secondary/10 flex items-center justify-center">
              <.icon name="hero-plus" class="w-6 h-6 text-secondary" />
            </div>
            <div class="flex-1">
              <h3 class="font-semibold">Add TV Show</h3>
              <p class="text-sm text-base-content/60">Search and add series</p>
            </div>
          </div>
        </.link>

        <.link
          navigate={~p"/import"}
          class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow"
        >
          <div class="card-body flex-row items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center">
              <.icon name="hero-arrow-down-tray" class="w-6 h-6 text-accent" />
            </div>
            <div class="flex-1">
              <h3 class="font-semibold">Import Files</h3>
              <p class="text-sm text-base-content/60">Scan and import media</p>
            </div>
          </div>
        </.link>

        <%= if @pending_requests_count > 0 do %>
          <.link
            navigate={~p"/admin/requests"}
            class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow border-2 border-warning"
          >
            <div class="card-body flex-row items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-warning/10 flex items-center justify-center">
                <.icon name="hero-inbox-stack" class="w-6 h-6 text-warning" />
              </div>
              <div class="flex-1">
                <h3 class="font-semibold">Pending Requests</h3>
                <p class="text-sm text-base-content/60">
                  {@pending_requests_count} request(s) awaiting review
                </p>
              </div>
              <%= if @pending_requests_count > 0 do %>
                <div class="badge badge-warning">{@pending_requests_count}</div>
              <% end %>
            </div>
          </.link>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Trending Movies -->
  <div class="mb-6 md:mb-8">
    <div class="flex items-center justify-between mb-3 md:mb-4">
      <h2 class="text-2xl font-bold">Trending Movies</h2>
      <.link navigate={~p"/discover?#{%{"type" => "movie"}}"} class="btn btn-sm btn-ghost">
        View All <.icon name="hero-arrow-right" class="w-4 h-4 ml-1" />
      </.link>
    </div>

    <%= cond do %>
      <% @trending_movies_loading -> %>
        <div class="flex items-center justify-center py-12">
          <span class="loading loading-spinner loading-lg"></span>
        </div>
      <% @trending_movies == [] -> %>
        <div class="alert alert-info">
          <.icon name="hero-information-circle" class="w-5 h-5" />
          <span>No trending movies available at the moment.</span>
        </div>
      <% true -> %>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 md:gap-4">
          <%= for movie <- @trending_movies do %>
            <.trending_card
              item={movie}
              media_type={:movie}
              current_user={@current_user}
              adding_item_id={@adding_item_id}
            />
          <% end %>
        </div>
    <% end %>
  </div>

  <!-- Trending TV Shows -->
  <div class="mb-6 md:mb-8">
    <div class="flex items-center justify-between mb-3 md:mb-4">
      <h2 class="text-2xl font-bold">Trending TV Shows</h2>
      <.link navigate={~p"/discover?#{%{"type" => "tv_show"}}"} class="btn btn-sm btn-ghost">
        View All <.icon name="hero-arrow-right" class="w-4 h-4 ml-1" />
      </.link>
    </div>

    <%= cond do %>
      <% @trending_tv_loading -> %>
        <div class="flex items-center justify-center py-12">
          <span class="loading loading-spinner loading-lg"></span>
        </div>
      <% @trending_tv == [] -> %>
        <div class="alert alert-info">
          <.icon name="hero-information-circle" class="w-5 h-5" />
          <span>No trending TV shows available at the moment.</span>
        </div>
      <% true -> %>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 md:gap-4">
          <%= for show <- @trending_tv do %>
            <.trending_card
              item={show}
              media_type={:tv_show}
              current_user={@current_user}
              adding_item_id={@adding_item_id}
            />
          <% end %>
        </div>
    <% end %>
  </div>

  <!-- User Activity Section (for users with monitored content) -->
  <%= if @recent_episodes != [] || @upcoming_episodes != [] do %>
    <div class="mb-6 md:mb-8">
      <h2 class="text-2xl font-bold mb-3 md:mb-4">Your Activity</h2>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 md:gap-4">
        <!-- Recent Episodes -->
        <%= if @recent_episodes != [] do %>
          <div class="card bg-base-100 shadow-sm">
            <div class="card-body">
              <h3 class="card-title text-lg">
                <.icon name="hero-clock" class="w-5 h-5" /> Recently Aired
              </h3>
              <div class="space-y-2">
                <%= for episode <- @recent_episodes do %>
                  <div class="flex items-start gap-3 p-2 rounded hover:bg-base-200 transition-colors">
                    <div class="flex-1 min-w-0">
                      <p class="font-medium text-sm truncate">{episode.media_item_title}</p>
                      <p class="text-xs text-base-content/70">
                        S{String.pad_leading(to_string(episode.season_number), 2, "0")}E{String.pad_leading(
                          to_string(episode.episode_number),
                          2,
                          "0"
                        )} - {episode.title}
                      </p>
                      <p class="text-xs text-base-content/50">
                        {Calendar.strftime(episode.air_date, "%b %d, %Y")}
                      </p>
                    </div>
                    <%= if episode.has_files do %>
                      <.icon name="hero-check-circle" class="w-5 h-5 text-success flex-shrink-0" />
                    <% else %>
                      <.icon
                        name="hero-arrow-down-tray"
                        class="w-5 h-5 text-warning flex-shrink-0"
                      />
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Upcoming Episodes -->
        <%= if @upcoming_episodes != [] do %>
          <div class="card bg-base-100 shadow-sm">
            <div class="card-body">
              <h3 class="card-title text-lg">
                <.icon name="hero-calendar" class="w-5 h-5" /> Coming Soon
              </h3>
              <div class="space-y-2">
                <%= for episode <- @upcoming_episodes do %>
                  <div class="flex items-start gap-3 p-2 rounded hover:bg-base-200 transition-colors">
                    <div class="flex-1 min-w-0">
                      <p class="font-medium text-sm truncate">{episode.media_item_title}</p>
                      <p class="text-xs text-base-content/70">
                        S{String.pad_leading(to_string(episode.season_number), 2, "0")}E{String.pad_leading(
                          to_string(episode.episode_number),
                          2,
                          "0"
                        )} - {episode.title}
                      </p>
                      <p class="text-xs text-base-content/50">
                        {Calendar.strftime(episode.air_date, "%b %d, %Y")}
                      </p>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Getting Started (shown when library is empty) -->
  <%= if @movie_count == 0 && @tv_show_count == 0 do %>
    <div class="alert alert-info">
      <.icon name="hero-information-circle" class="w-5 h-5" />
      <div>
        <p class="font-semibold">Getting Started</p>
        <p class="text-sm">
          Your media library is empty. Start by adding movies or TV shows from the trending content above!
        </p>
      </div>
    </div>
  <% end %>

  <%!-- Trending Detail Modal --%>
  <.live_component
    module={MydiaWeb.Live.Components.TrendingDetailModal}
    id="trending-detail-modal"
    item={@selected_item}
    metadata={@selected_metadata}
    loading={@detail_loading}
    current_user={@current_user}
    open={@selected_item != nil}
  />
</Layouts.app>
